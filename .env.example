# ============================================
# 🚀 ZONE DELIVERY - ENVIRONMENT VARIABLES
# ============================================
# এটি একটি example file - এটি copy করুন .env এ এবং values fill করুন

# ============ LOCAL DEVELOPMENT SETTINGS ============
DEBUG=True
ENVIRONMENT=development
RENDER=False

# ============ SECURITY CONFIGURATION ============
# Change this in production!
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-your-secret-key-change-this-in-production

# ============ ADMIN LOGIN CREDENTIALS ============
# Optional: set these to create a default admin user from .env
ADMIN_CREATE_DEFAULT=False
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
ADMIN_EMAIL=admin@example.com

# ============ ALLOWED HOSTS ============
# Local development: localhost,127.0.0.1,*.ngrok-free.dev
ALLOWED_HOSTS=localhost,127.0.0.1

# ============ DATABASE CONFIGURATION ============
# LOCAL DEVELOPMENT: Leave empty to use SQLite
DATABASE_URL=

# OR use PostgreSQL locally (optional):
# DATABASE_URL=postgresql://user:password@localhost:5432/zonedelivery

# ============ CLOUDINARY CONFIGURATION ============
# 🔗 Get free tier account: https://cloudinary.com/users/register/free
# 📊 Find credentials: https://cloudinary.com/console/c_a52411ee76c6c8217a92299801b
# 
# Steps:
# 1. Create Cloudinary account
# 2. Go to Dashboard/Settings
# 3. Copy these values:

CLOUDINARY_CLOUD_NAME=dyav7evol
CLOUDINARY_API_KEY=719484321234681
CLOUDINARY_API_SECRET=vD-xu6YjR9ZDOPWaZc1Nrh3R3_E

# ============ GOOGLE MAPS API (OPTIONAL) ============
# Only needed if you're using map features
GOOGLE_MAPS_API_KEY=

# ============ GOOGLE OAUTH LOGIN (OPTIONAL) ============
# Create credentials at https://console.cloud.google.com/apis/credentials
# Redirect URI should match the value configured in Google Cloud.
# Example redirect URIs:
# http://localhost:8000/auth/google/callback
# https://zonedelevary.store/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ============ EMAIL CONFIGURATION (OPTIONAL) ============
# Local development: Console backend (emails print to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ============ OPTIONAL: REDIS CACHING ============
# For production caching (not needed for local dev)
# REDIS_URL=redis://localhost:6379/0

# ============ PRODUCTION SETTINGS (For Render) ============
# When deploying to Render, set these:
# DEBUG=False
# ENVIRONMENT=production
# RENDER=True
# ALLOWED_HOSTS=your-app-name.onrender.com,localhost
# DATABASE_URL=postgresql://... (auto from Render PostgreSQL)
# SECRET_KEY=<generate new strong key>
# CSRF_TRUSTED_ORIGINS=https://your-app-name.onrender.com

# ============ DEVELOPMENT SETTINGS ============
# Local development এ ngrok use করার জন্য
# SECURE_SSL_REDIRECT=False
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
# CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://*.ngrok-free.dev,https://*.ngrok.io

# ============ RENDER PRODUCTION SETTINGS ============
# Render নিজেই automatic set করে এই settings গুলো
# RENDER=True
# ENVIRONMENT=production
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
