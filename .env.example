# ============================================
# ZONE DELIVERY - ENVIRONMENT VARIABLES
# ============================================

# ============ SECURITY CONFIGURATION ============
# Django secret key - একটি random secure key generate করুন
# Generate: python manage.py shell -> from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())
SECRET_KEY=your-unique-secret-key-here-must-be-strong

# Debug mode (False for production)
DEBUG=False

# ============ ALLOWED HOSTS ============
# আপনার সব domain names (comma separated)
# Local development example: localhost,127.0.0.1,*.ngrok-free.dev,*.ngrok.io
# Render production example: your-app-name.onrender.com,localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# ============ DATABASE CONFIGURATION ============
# For Render: Render automatically provide করে যখন আপনি PostgreSQL add করেন
# Format: postgresql://username:password@hostname:port/database_name
DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# Optional: Redis for caching (Render এ optional)
# REDIS_URL=redis://default:password@hostname:port

# ============ CLOUDINARY CONFIGURATION ============
# Free tier: 100GB storage, unlimited images
# 1. https://cloudinary.com/users/register/free এ signup করুন
# 2. Dashboard এ যান
# 3. এই details copy করুন:
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============ GOOGLE MAPS API (Optional) ============
# যদি map feature ব্যবহার করেন তখন আপনার API key দিন
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ============ EMAIL CONFIGURATION (Optional) ============
# Local development এ console backend ব্যবহার করুন
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production email configuration (Optional)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-specific-password

# ============ DEVELOPMENT SETTINGS ============
# Local development এ ngrok use করার জন্য
# SECURE_SSL_REDIRECT=False
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
# CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://*.ngrok-free.dev,https://*.ngrok.io

# ============ RENDER PRODUCTION SETTINGS ============
# Render নিজেই automatic set করে এই settings গুলো
# RENDER=True
# ENVIRONMENT=production
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
